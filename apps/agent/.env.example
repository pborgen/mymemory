# Which provider + model is active is configured in models.json ("active" field).
# Set credentials for whichever provider you use below.

# --- bedrock (AWS) ---
# Credentials resolve via the standard AWS chain. For local dev set these, or
# rely on `aws configure` / SSO / an instance role in deployed environments.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- anthropic (paid) ---
ANTHROPIC_API_KEY=

# --- groq (free tier at console.groq.com) ---
GROQ_API_KEY=

# --- ollama (run `ollama serve` locally) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- MyMemory API the agent's tools call ---
MEMORY_API_URL=http://localhost:8080
MEMORY_USER_EMAIL=paul@dev.local
