# PostgreSQL connection string. The database must have the pgvector extension
# available — the app runs `CREATE EXTENSION IF NOT EXISTS vector` on startup.
POSTGRES_URL=postgresql://postgres@localhost:5432/mymemory

# Server port.
PORT=8080

# Enable dev auth via the `x-user-email` header and expose dev accounts.
ALLOW_DEV_AUTH_HEADERS=true

# Google OAuth client id for production sign-in (leave blank in dev).
GOOGLE_CLIENT_ID=

# AWS region for the Bedrock-hosted Claude model + Titan embeddings.
# Credentials resolve via the standard AWS chain (env vars, SSO, instance role).
AWS_REGION=us-east-1

# Bedrock model (cross-region inference profile) for answer generation.
# Default is Claude Haiku 4.5 — cheap and current.
RAG_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Bedrock embedding model. Titan Text Embeddings v2 outputs 1024-dim vectors;
# this must match the VECTOR(n) column width in db.py (EMBED_DIM).
EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
