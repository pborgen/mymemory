# PostgreSQL connection string. The database must have the pgvector extension
# available — the app runs `CREATE EXTENSION IF NOT EXISTS vector` on startup.
POSTGRES_URL=postgresql://postgres@localhost:5432/mymemory

# Server port.
PORT=8080

# Enable dev auth via the `x-user-email` header and expose dev accounts.
ALLOW_DEV_AUTH_HEADERS=true

# Redis connection string for the shared prompt cache. Optional: if unset, the
# prompt resolver reads straight through to Postgres (fine for local dev).
REDIS_URL=redis://localhost:6379/0

# Google OAuth client id for production sign-in (leave blank in dev).
GOOGLE_CLIENT_ID=

# Generation and embeddings are configured separately (one server often provides
# only one of them — e.g. a vLLM chat server has no embeddings endpoint).
# Each provider is one of: openai | ollama | bedrock.

# --- Generation (answer + classification) ---
#   openai  — any OpenAI-compatible server (vLLM, LM Studio, LiteLLM, …)
#   ollama  — an Ollama server (/api/chat)
#   bedrock — AWS Bedrock Converse
GEN_PROVIDER=openai
# OpenAI-compatible chat server (GEN_PROVIDER=openai). vLLM example over Tailscale:
OPENAI_BASE_URL=http://localhost:8001/v1
OPENAI_CHAT_MODEL=Qwen/Qwen2.5-0.5B-Instruct
OPENAI_API_KEY=not-needed
# Ollama chat (GEN_PROVIDER=ollama):
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
# Bedrock chat (GEN_PROVIDER=bedrock): cross-region inference profile.
RAG_MODEL_ID=us.amazon.nova-2-lite-v1:0

# --- Embeddings ---
#   openai  — OpenAI-compatible /v1/embeddings (e.g. a vLLM/TEI embed server)
#   ollama  — Ollama /api/embeddings
#   bedrock — Amazon Titan
# EMBED_DIM MUST match the VECTOR(n) column in db.py; changing it recreates that
# column (existing memories are re-embedded).
EMBED_PROVIDER=openai
EMBED_BASE_URL=http://localhost:8002/v1
EMBED_MODEL_ID=BAAI/bge-small-en-v1.5
EMBED_API_KEY=not-needed
EMBED_DIM=384

# AWS region for Bedrock (only when GEN/EMBED provider = bedrock).
# Credentials resolve via the standard AWS chain (env vars, SSO, instance role).
AWS_REGION=us-east-1
